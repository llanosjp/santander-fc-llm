# ── API Santander (Power Automate) ────────────────────────────────────────────
SANTANDER_API_URL=https://prod-XX.westus.logic.azure.com/workflows/...

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
MODEL=gpt-4o

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
# PHONE_NUMBER_ID: en modo prueba usá el ID del número de test que da Meta.
# Cuando llegue el número real, solo cambiás este valor. El código no cambia.
WHATSAPP_PHONE_NUMBER_ID=1234567890

# Access token temporal (24h) durante desarrollo.
# En producción usá un token permanente via System User en Meta Business Manager.
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx

# Token secreto que inventás vos — Meta lo envía en el GET de verificación.
# Puede ser cualquier string, ej: "santander-wsp-2026"
WHATSAPP_VERIFY_TOKEN=santander-wsp-2026

# Versión de Graph API — no cambiar salvo que Meta deprecate la actual.
WHATSAPP_API_VERSION=v19.0
