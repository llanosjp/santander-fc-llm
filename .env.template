# ── API Santander (Power Automate) ────────────────────────────────────────────
# URL del workflow de Power Automate que expone los datos de colocaciones
SANTANDER_API_URL=https://prod-XX.westus.logic.azure.com/workflows/...

# ── LLM ───────────────────────────────────────────────────────────────────────
# API key de OpenAI (obtener en: https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Modelo a usar (gpt-4o recomendado para function calling)
MODEL=gpt-4o

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
# Phone Number ID del número de WhatsApp
# - En desarrollo: usar el número de prueba de Meta Developer Portal
# - En producción: usar el ID del número verificado (+51 960666442)
WHATSAPP_PHONE_NUMBER_ID=1234567890

# Access Token de Meta Business
# - Temporal (24h): obtener en Meta Developer Portal → WhatsApp → API Setup
# - Permanente: crear System User en Meta Business Manager
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx

# Token de verificación del webhook (inventar uno único)
# Meta lo usa para verificar que controlás el servidor
WHATSAPP_VERIFY_TOKEN=santander-wsp-2026

# Versión de Graph API (no cambiar salvo que Meta deprecate v19.0)
WHATSAPP_API_VERSION=v19.0
